{
  "name": "@spots/root",
  "version": "0.1.0",
  "description": "Spots - AI-powered location discovery platform",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo run dev --filter=!@spots/backend",
    "dev:all": "turbo run dev",
    "dev:backend": "pnpm -C packages/backend dev",
    "lint": "ultracite check",
    "format": "ultracite fix",
    "doctor": "ultracite doctor",
    "test": "turbo test",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "pnpm test:unit && pnpm test:e2e",
    "analyze": "turbo analyze",
    "boundaries": "turbo boundaries",
    "bump-deps": "npx npm-check-updates --deep -u -x react-day-picker && pnpm install",
    "bump-ui": "npx shadcn@latest add --all --overwrite -c packages/design",
    "clean": "git clean -xdf node_modules"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "2.2.3",
    "@spots/typescript-config": "workspace:*",

    "@types/node": "^24.3.1",

    "turbo": "^2.5.6",
    "typescript": "^5.9.2",
    "ultracite": "^5.3.4"
  },
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=20"
  }
}
